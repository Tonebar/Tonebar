{
  "name": "lr-remote-bridge-app",
  "version": "0.1.0",
  "private": true,
  "description": "Menu-bar bridge connecting the Remote Slider Control phone app to the Lightroom Classic plugin",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.example.lrremotebridge",
    "productName": "Remote Slider Control Bridge",
    "files": ["src/**/*", "assets/**/*"],
    "mac": {
      "category": "public.app-category.photography",
      "target": ["dmg"],
      "icon": "assets/app-icon-1024.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": ["nsis"],
      "icon": "assets/app-icon-1024.png"
    }
  }
}
